# backend/.env  (for local development only — use AWS SSM in production)

DATABASE_URL=postgresql://user:password@localhost:5432/video_editor
JWT_SECRET=your-user-jwt-secret-256-bit
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
S3_BUCKET=video-editor-prod-assets
CDN_DOMAIN=cdn.videoeditorpro.app
AWS_REGION=us-east-1
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-secret
SMTP_HOST=smtp.sendgrid.net
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-key
SMTP_FROM=noreply@videoeditorpro.app
