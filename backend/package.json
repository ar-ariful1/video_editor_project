    "logs:subscriptions": "serverless logs -f subscriptions --tail",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.511.0",
    "@aws-sdk/s3-request-presigner": "^3.511.0",
    "bcryptjs": "^2.4.3",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.9",
    "otplib": "^12.0.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "serverless": "^3.38.0"
  }
}
