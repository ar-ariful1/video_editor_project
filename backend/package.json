{
  "name": "video-editor-backend",
  "version": "1.0.0",
  "description": "AWS Lambda backend for Video Editor Pro",
  "private": true,
  "scripts": {
    "deploy": "serverless deploy --stage prod",
    "deploy:dev": "serverless deploy --stage dev",
    "remove": "serverless remove",
    "logs:auth": "serverless logs -f auth --tail",
